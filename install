#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

MIN_NODE_MAJOR=20
MIN_NODE_MINOR=9
MIN_PYTHON_MAJOR=3
MIN_PYTHON_MINOR=11
PYTHON_BIN=""

say() {
  printf '\n==> %s\n' "$1"
}

pass() {
  printf 'OK   %s\n' "$1"
}

warn() {
  printf 'WARN %s\n' "$1"
}

die() {
  printf '\nErreur: %s\n' "$1" >&2
  exit 1
}

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

is_macos() {
  [ "$(uname -s)" = "Darwin" ]
}

brew_ensure_formula() {
  local formula="$1"
  local label="$2"

  if ! has_cmd brew; then
    die "$label est manquant. Installe Homebrew depuis https://brew.sh puis relance ./install."
  fi

  if brew list --formula "$formula" >/dev/null 2>&1; then
    say "Mise a jour de $label via Homebrew"
    brew upgrade "$formula" || true
  else
    say "Installation de $label via Homebrew"
    brew install "$formula"
  fi

  hash -r
}

node_version_ok() {
  has_cmd node && node -e "
const [major, minor] = process.versions.node.split('.').map(Number);
process.exit(major > $MIN_NODE_MAJOR || (major === $MIN_NODE_MAJOR && minor >= $MIN_NODE_MINOR) ? 0 : 1);
" >/dev/null 2>&1
}

ensure_node() {
  say "Verification de Node.js"

  if ! node_version_ok || ! has_cmd npm; then
    if is_macos; then
      brew_ensure_formula "node" "Node.js"
    fi
  fi

  if ! node_version_ok; then
    local detected="absent"
    if has_cmd node; then
      detected="$(node -v)"
    fi
    die "Node.js >= ${MIN_NODE_MAJOR}.${MIN_NODE_MINOR} est requis. Version detectee: $detected."
  fi

  if ! has_cmd npm; then
    die "npm est manquant alors que Node.js est installe."
  fi

  pass "Node.js $(node -v)"
  pass "npm $(npm -v)"
}

python_version_ok() {
  local python="$1"
  "$python" - <<PY >/dev/null 2>&1
import sys
sys.exit(0 if sys.version_info >= ($MIN_PYTHON_MAJOR, $MIN_PYTHON_MINOR) else 1)
PY
}

python_version() {
  local python="$1"
  "$python" - <<'PY'
import sys
print(f"{sys.version_info.major}.{sys.version_info.minor}.{sys.version_info.micro}")
PY
}

find_compatible_python() {
  local candidate

  if [ -n "${PYTHON:-}" ] && [ -x "${PYTHON:-}" ] && python_version_ok "$PYTHON"; then
    printf '%s\n' "$PYTHON"
    return 0
  fi

  if [ -n "${PYTHON:-}" ] && has_cmd "$PYTHON" && python_version_ok "$PYTHON"; then
    command -v "$PYTHON"
    return 0
  fi

  for candidate in python3.14 python3.13 python3.12 python3.11 python3; do
    if has_cmd "$candidate" && python_version_ok "$candidate"; then
      command -v "$candidate"
      return 0
    fi
  done

  return 1
}

ensure_python() {
  say "Verification de Python"

  if ! PYTHON_BIN="$(find_compatible_python)"; then
    if is_macos; then
      brew_ensure_formula "python@3.12" "Python 3.12"
    fi
  fi

  if ! PYTHON_BIN="$(find_compatible_python)"; then
    die "Python >= ${MIN_PYTHON_MAJOR}.${MIN_PYTHON_MINOR} est requis. Installe Python 3.11+ puis relance ./install."
  fi

  pass "Python $(python_version "$PYTHON_BIN") ($PYTHON_BIN)"
}

install_node_dependencies() {
  say "Installation des dependances Node"
  npm install
}

install_python_dependencies() {
  say "Preparation de Python"

  if [ -x ".venv/bin/python" ] && python_version_ok ".venv/bin/python"; then
    pass "venv Python $(python_version ".venv/bin/python")"
  else
    if [ -d ".venv" ]; then
      warn ".venv utilise une version Python trop ancienne, recreation"
      rm -rf .venv
    fi
    "$PYTHON_BIN" -m venv .venv
    pass "venv cree avec Python $(python_version ".venv/bin/python")"
  fi

  .venv/bin/python -m pip install --upgrade pip
  .venv/bin/python -m pip install -r requirements.txt
}

prepare_local_files() {
  say "Preparation des fichiers locaux"

  if [ ! -f ".env" ]; then
    cp .env.example .env
    warn ".env cree depuis .env.example; complete les identifiants Tapo ou utilise l onboarding"
  else
    pass ".env existe deja"
  fi

  if [ ! -f "domus-scenes.json" ]; then
    printf '{"scenes":[]}\n' > domus-scenes.json
    pass "domus-scenes.json cree"
  else
    pass "domus-scenes.json existe deja"
  fi
}

install_global_cli() {
  say "Installation globale du CLI"

  if ! npm link; then
    die "npm link a echoue. Verifie les permissions du prefix npm global: npm config get prefix"
  fi

  if ! has_cmd domus; then
    die "Le binaire global domus est introuvable apres npm link."
  fi

  if ! domus help >/dev/null 2>&1; then
    die "Le binaire global domus est installe mais ne repond pas correctement."
  fi

  pass "domus disponible globalement: $(command -v domus)"
}

verify_build() {
  say "Verification du build"
  npm run build
}

final_check() {
  say "Verification finale"
  ./doctor.sh
}

ensure_node
ensure_python
install_node_dependencies
install_python_dependencies
prepare_local_files
verify_build
install_global_cli
final_check

cat <<'EOF'

DOMUS est pret.

Commandes utiles:
  domus help
  domus list
  npm run dev

Puis ouvre l adresse affichee par Next.js et suis l onboarding Tapo si .env n est pas encore configure.
EOF
